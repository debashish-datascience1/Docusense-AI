# DocuSense AI — environment configuration
# Copy this file to .env and fill in the values you need.
# .env is git-ignored: keys never leave your machine.
#
# The backend is selected automatically from which keys are present:
#
#   VERTEX_AI_MOCK=true          → mock mode (zero setup, fake answers)
#   GROQ_API_KEY=<key>           → Groq (free, local embeddings)
#   GROQ_API_KEY + GEMINI_API_KEY → Groq generation + Gemini embeddings
#   GEMINI_API_KEY=<key>         → Google AI Studio (free Gemini stack)
#   (no keys)                    → Vertex AI (needs GCP billing + ADC login)

# ── Free tiers (pick one or combine) ───────────────────────────────────────

# Groq — https://console.groq.com/keys  (free tier, very fast inference)
GROQ_API_KEY=

# Google AI Studio — https://aistudio.google.com/apikey  (free Gemini quota)
GEMINI_API_KEY=

# ── Mock mode (overrides everything above) ──────────────────────────────────
# VERTEX_AI_MOCK=true

# ── Vertex AI / GCP (production; billing required) ─────────────────────────
# GCP_PROJECT_ID=your-project-id
# GCP_LOCATION=us-central1
# GCS_BUCKET=your-project-id-docusense-documents

# ── Model overrides (optional) ──────────────────────────────────────────────
# GROQ_MODEL=llama-3.3-70b-versatile
# AI_STUDIO_GENERATION_MODEL=gemini-2.5-flash
# AI_STUDIO_EMBEDDING_MODEL=gemini-embedding-001
# LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Server ──────────────────────────────────────────────────────────────────
# API_PORT=8080
# BACKEND_URL=http://localhost:8080
